# Docker Compose 의존성
POSTGRES_DB=mower
POSTGRES_USER=mower
POSTGRES_PASSWORD=mower
POSTGRES_PORT=5432

# 백엔드
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mower
SPRING_DATASOURCE_USERNAME=mower
SPRING_DATASOURCE_PASSWORD=mower
JWT_SECRET=change-me-to-a-32-byte-minimum-secret
JWT_EXPIRATION=PT8H
MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=autonomous-mower-backend

# 프론트엔드 통합 모드
VITE_API_PROXY_TARGET=http://localhost:8080
VITE_ENABLE_MOCK_AUTH=false
VITE_ENABLE_MOCK_CONTROL=false
VITE_ENABLE_MOCK_ROBOTS=false
VITE_ENABLE_MOCK_REALTIME=true
VITE_WSS_URL=ws://localhost:8080/ws
VITE_WEBRTC_SIGNALING_URL=

# Edge Mock
ROBOT_ID=MOWER-01
# tools/edge-mock-client 시작 시 이 값을 MQTT_BROKER_URL로 사용하세요.
EDGE_MQTT_BROKER_URL=mqtt://localhost:1883
TELEMETRY_INTERVAL_MS=1000
STATUS_INTERVAL_MS=3000
EVENT_INTERVAL_MS=15000
